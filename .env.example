# Root-level environment placeholders for CoVeX bootstrap
APP_ENV=development
LOG_LEVEL=INFO

# Optional remote provider credentials for commented examples in config/inference_engines.yaml
COVEX_OPENROUTER_API_KEY=your-openrouter-api-key
COVEX_OPENAI_API_KEY=your-openai-api-key
COVEX_ANTHROPIC_API_KEY=your-anthropic-api-key
COVEX_MISTRAL_API_KEY=your-mistral-api-key
COVEX_GEMINI_API_KEY=your-gemini-api-key
COVEX_GROQ_API_KEY=your-groq-api-key
COVEX_GOOGLE_API_KEY=your-google-api-key
